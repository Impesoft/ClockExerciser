<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Clock_Exerciser"
             xmlns:shared="clr-namespace:Clock_Exerciser.Shared;assembly=Clock_Exerciser.Shared"
             x:Class="Clock_Exerciser.MainPage"
             BackgroundColor="{AppThemeBinding Light=White, Dark=#121212}">

    <BlazorWebView x:Name="blazorWebView" HostPage="wwwroot/index.html">
        <BlazorWebView.RootComponents>
            <RootComponent Selector="#app" ComponentType="{x:Type shared:Routes}" />
        </BlazorWebView.RootComponents>
    </BlazorWebView>

</ContentPage>
